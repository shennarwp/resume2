{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":autodetectPinVersions",
    ":automergePatch",
    ":prImmediately",
    ":rebaseStalePrs",
    ":timezone(Europe/Berlin)",
    "helpers:pinGitHubActionDigests",
    "npm:unpublishSafe",
    ":semanticCommits",
    ":semanticCommitType(fix)",
    ":semanticCommitScope(deps)",
    ":updateNotScheduled",
    "preview:dockerCompose",
    "preview:dockerVersions",
    "workarounds:typesNodeVersioning",
    ":disablePeerDependencies",
    "schedule:automergeDaily",
    ":dependencyDashboard",
    "group:recommended"
  ],
  "baseBranches": ["main"],
  "rebaseWhen": "conflicted",
  "addLabels": ["dependencies", "renovate"],
  "rangeStrategy": "bump",
  "postUpdateOptions": ["npmDedupe", "pnpmDedupe", "yarnDedupeFewer"],
  "transitiveRemediation": true,
  "separateMajorMinor": true,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "vulnerabilityAlerts": {
    "semanticCommitType": "fix",
    "semanticCommitScope": "security",
    "labels": ["security"]
  },
  "automergeStrategy": "merge-commit",
  "packageRules": [
    {
      "description": "Group major updates together",
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["major"],
      "reviewersFromCodeOwners": true,
      "addLabels": ["major", "version-update"],
      "groupName": "major"
    },
    {
      "description": "Group minor updates together",
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["minor"],
      "addLabels": ["minor"],
      "groupName": "minor"
    },
    {
      "description": "Group patch updates together and automerge if tests pass",
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["patch"],
      "addLabels": ["patch"],
      "groupName": "patch"
    },
    {
      "description": "Group pin updates together and automerge if tests pass",
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["pin", "digest"],
      "addLabels": ["pin"],
      "groupName": "pin"
    },
    {
      "description": "Automerge any updates to types",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor"],
      "addLabels": ["minor"],
      "matchPackageNames": ["@types/**"],
      "groupName": "minor-types",
      "automerge": true
    },
    {
      "description": "Automerge any updates to linting or prettier",
      "matchDepTypes": ["devDependencies"],
      "matchPackageNames": ["*lint*", "*prettier*"],
      "automerge": true
    },
    {
      "description": "Separate alpine minor and patch",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["*alpine*"],
      "separateMinorPatch": true
    },
    {
      "description": "Automerge alpine patch updates",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["*alpine*"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Automerge Github Actions minor and patch updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Separate multiple major Github Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "separateMultipleMajor": true
    },
    {
      "description": "Group node major updates",
      "matchDepNames": ["node"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"],
      "groupName": "node major"
    },
    {
      "description": "Group pnpm major updates",
      "matchDepNames": ["pnpm"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"],
      "groupName": "pnpm major"
    },
    {
      "description": "Group npm major updates",
      "matchDepNames": ["npm"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"],
      "groupName": "npm major"
    },
    {
      "description": "Group Typescript major updates",
      "matchDepNames": ["typescript"],
      "matchUpdateTypes": ["major"],
      "groupName": "typescript major"
    }
  ],
  "platform": "github",
  "onboarding": false,
  "requireConfig": "ignored"
}